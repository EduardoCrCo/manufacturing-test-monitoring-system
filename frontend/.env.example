# Frontend Environment Variables Example
# Copy this file to .env.production and configure for your deployment

# Backend API URL - Update with your Render deployment URL
VITE_API_URL=https://your-app-name.onrender.com/api

# App Configuration
VITE_APP_NAME="Manufacturing Test Monitoring"
VITE_APP_VERSION="1.0.0"

# Note: All environment variables for Vite must start with VITE_